{
  "version": "v5",
  "date": "2026-05-28",
  "purpose": "Delta Index + WAL + Top-K Merge + SLA-aware Compaction mixed workload validation",
  "dataset": {
    "type": "synthetic",
    "workload": "agent",
    "base_count": 2000,
    "query_count": 300,
    "dim": 64,
    "clusters": 32,
    "session_length": 10,
    "seed": 42,
    "ground_truth": "dynamic exact brute force over main base plus current delta"
  },
  "index": {
    "engine": "graph",
    "layout": "packed",
    "packing": "coaccess",
    "graph_degree": 16,
    "page_size": 4096,
    "search_width": 128,
    "entry_count": 48,
    "routing_sample_count": 512,
    "cache_policy": "agent",
    "cache_pages": 24,
    "path_cache_policy": "reuse",
    "path_cache_capacity": 128,
    "path_cache_hit_search_width": 96
  },
  "mixed_workload": {
    "operation_count": 360,
    "write_ratio_percent": 20,
    "expected_query_count": 288,
    "expected_insert_count": 72
  },
  "delta_and_wal": {
    "wal_files": [
      "build/v5_none.wal",
      "build/v5_aggressive.wal",
      "build/v5_sla.wal"
    ],
    "delta_compaction_threshold": 24,
    "compaction_batch_size": 8,
    "compaction_work_us": 700
  },
  "variants": [
    {
      "name": "no_compaction",
      "compaction_policy": "none"
    },
    {
      "name": "aggressive_compaction",
      "compaction_policy": "aggressive"
    },
    {
      "name": "sla_compaction",
      "compaction_policy": "sla",
      "sla_p99_ms": 0.6
    }
  ],
  "pass_criteria": {
    "build_success": true,
    "recall_at_10_min": 0.95,
    "wal_records_equal_insert_count": true,
    "delta_results_merged_with_main": true,
    "insert_latency_observable": true,
    "sla_query_p99_lower_than_aggressive": true,
    "sla_query_compaction_interference_lower_than_aggressive": true,
    "archive_config_log_result_build_info": true
  },
  "run_command": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run_v5_mixed_compare.ps1"
}
